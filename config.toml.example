# Navidrome Client Configuration
# You can edit server_url and username.
# Password is encrypted and stored by the application in app.redb.

server_url = "http://your-navidrome-server:4533"
username = "your-username"


[theme.dark.accent]
border_dark = "#458588"
border_light = "#83a598"
bright = "#83a598"
primary = "#458588"
# now_playing = ""            # Slot highlight for currently-playing (defaults to primary)
# selected = ""              # Center/selected slot highlight (defaults to bright)

[theme.dark.aqua]
bright = "#8ec07c"
normal = "#689d6a"

[theme.dark.background]
default = "#282828"
hard = "#1d2021"
level1 = "#3c3836"
level2 = "#504945"
level3 = "#665c54"
level4 = "#7c6f64"
soft = "#32302f"

[theme.dark.foreground]
bright = "#fbf1c7"
gray = "#928374"
level1 = "#ebdbb2"
level2 = "#d5c4a1"
level3 = "#bdae93"
level4 = "#a89984"

[theme.dark.green]
bright = "#b8bb26"
normal = "#98971a"

[theme.dark.orange]
bright = "#fe8019"
normal = "#d65d0e"

[theme.dark.purple]
bright = "#d3869b"
normal = "#b16286"

[theme.dark.red]
bright = "#fb4934"
normal = "#cc241d"

[theme.dark.yellow]
bright = "#fabd2f"
normal = "#d79921"

[theme.font]
family = "JetBrainsMono Nerd Font"

[theme.light.accent]
border_dark = "#458588"
border_light = "#d5c4a1"
bright = "#83a598"
primary = "#458588"
# now_playing = ""            # Slot highlight for currently-playing (defaults to primary)
# selected = ""              # Center/selected slot highlight (defaults to bright)

[theme.light.aqua]
bright = "#8ec07c"
normal = "#689d6a"

[theme.light.background]
default = "#fbf1c7"
hard = "#f9f5d7"
level1 = "#ebdbb2"
level2 = "#d5c4a1"
level3 = "#bdae93"
level4 = "#a89984"
soft = "#f2e5bc"

[theme.light.foreground]
bright = "#282828"
gray = "#928374"
level1 = "#3c3836"
level2 = "#504945"
level3 = "#665c54"
level4 = "#7c6f64"

[theme.light.green]
bright = "#b8bb26"
normal = "#98971a"

[theme.light.orange]
bright = "#fe8019"
normal = "#d65d0e"

[theme.light.purple]
bright = "#d3869b"
normal = "#b16286"

[theme.light.red]
bright = "#fb4934"
normal = "#cc241d"

[theme.light.yellow]
bright = "#fabd2f"
normal = "#d79921"

[visualizer]
height_percent = 0.20       # 20% of window height (0.1-0.6)
opacity = 1.0               # Overall visualizer opacity (0.0-1.0)
lower_cutoff_freq = 50      # Lowest frequency to visualize (Hz)
higher_cutoff_freq = 10000  # Highest frequency to visualize (Hz)
noise_reduction = 0.77      # Cava's smoothing 0.0-1.0 (higher = smoother but slower)

monstercat = 0.0            # Monstercat smoothing (0.0 = off, 0.7–10.0 = active; values below 0.7 snap to off)
waves = false               # Waves smoothing (mutually exclusive with monstercat)

[visualizer.bars]
bar_width_min = 2.0         # Bar width at small windows (400px)
bar_width_max = 12.0        # Bar width at large windows (2560px)
bar_spacing = 1.0
border_width = 1.0
led_bars = true
led_segment_height = 2.0
led_border_opacity = 1.0
gradient_mode = "wave"              # "static", "wave", "shimmer", "energy"
peak_gradient_mode = "cycle"        # "static", "cycle", "height", "match"
peak_mode = "fade"                  # "none", "fade", "fall", "fall_accel"
peak_hold_time = 1000                # ms before peak starts falling/fading
peak_fade_time = 750                # ms for fade to complete (fade mode only)
peak_height_ratio = 66               # peak bar height as % of bar width (non-LED mode)
bar_depth_3d = 0.0                   # isometric 3D depth in px (0=flat, max 20)

[visualizer.bars.dark]
border_color = "#1d2021"
bar_gradient_colors = [
    "#458588",
    "#518b8b",
    "#5e928f",
    "#83a598",
    "#83a598",
    "#83a598",
]
peak_gradient_colors = [
    "#fe8019",
    "#d65d0e",
    "#d79921",
    "#fabd2f",
    "#fe8019",
    "#d79921",
]

[visualizer.bars.light]
border_color = "#f9f5d7"
bar_gradient_colors = [
    "#458588",
    "#5a9a8a",
    "#689d6a",
    "#7daf73",
    "#8ec07c",
    "#b8bb26",
]
peak_gradient_colors = [
    "#d65d0e",
    "#d79921",
    "#fabd2f",
    "#fe8019",
    "#d65d0e",
    "#fabd2f",
]

[visualizer.lines]
point_count = 24            # Number of points to render (8-512)
line_thickness = 0.025      # Line thickness (0.001-0.1)
